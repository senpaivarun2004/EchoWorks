{
  "$schema": "https://turbo.build/schema.json",
  "pipeline": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**", ".next/**", "pkg/**"]
    },
    "build:wasm": {
      "dependsOn": ["^build:wasm"],
      "outputs": ["pkg/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "outputs": []
    },
    "test": {
      "outputs": ["coverage/**"],
      "dependsOn": []
    },
    "db:generate": {
      "outputs": ["prisma/client/**"]
    },
    "db:migrate": {
      "dependsOn": ["db:generate"]
    },
    "db:studio": {
      "cache": false
    },
    "clean": {
      "cache": false
    }
  },
  "globalEnv": ["DATABASE_URL", "JWT_SECRET", "S3_ENDPOINT", "S3_BUCKET", "S3_ACCESS_KEY", "S3_SECRET_KEY", "REDIS_URL", "SENTRY_DSN"]
}