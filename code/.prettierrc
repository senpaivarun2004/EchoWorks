{
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "es5",
  "printWidth": 100,
  "bracketSpacing": true,
  "arrowParens": "always",
  "endOfLine": "lf",
  "plugins": ["prettier-plugin-toml"],
  "overrides": [
    {
      "files": "*.rs",
      "options": {
        "tabWidth": 4
      }
    }
  ]
}